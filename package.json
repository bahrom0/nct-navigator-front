{
  "name": "mmt-navigator",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev:frontend": "next dev --webpack -H 0.0.0.0",
    "dev:backend": "npm --prefix backend run dev",
    "dev": "next dev --webpack -H 0.0.0.0",
    "build": "next build && npm run build:sites",
    "build:sites": "vinext build",
    "build:backend": "npm --prefix backend run build",
    "nct:stage1": "node scripts/nct_db/stage1.mjs",
    "nct:stage2": "node scripts/nct_db/stage2.mjs",
    "nct:stage2:verify": "node scripts/nct_db/verify-stage2.mjs",
    "nct:stage3": "node scripts/nct_db/stage3.mjs",
    "nct:stage3:verify": "node scripts/nct_db/verify-stage3.mjs",
    "nct:recommendations:verify": "tsx --tsconfig backend/tsconfig.json backend/scripts/evaluate-recommendation-production.ts",
    "start": "next start",
    "lint": "eslint"
  },
  "dependencies": {
    "framer-motion": "^12.40.0",
    "lucide-react": "^1.17.0",
    "next": "16.2.7",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-hook-form": "^7.78.0",
    "sonner": "^2.0.7",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.37.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitejs/plugin-rsc": "^0.5.26",
    "eslint": "^9",
    "eslint-config-next": "16.2.7",
    "pdfjs-dist": "^6.1.200",
    "prettier": "^3.8.4",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "qrcode-terminal": "^0.12.0",
    "react-server-dom-webpack": "^19.2.6",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vercel": "^54.14.0",
    "vinext": "^0.0.50",
    "vite": "^8.0.13",
    "wrangler": "^4.92.0"
  },
  "type": "module"
}
